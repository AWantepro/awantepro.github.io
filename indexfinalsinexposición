      display:inline-flex;align-items:center;justify-content:center;
      box-shadow:var(--shadow-soft);position:relative
    }
    .iconchip::after{
      content:"";position:absolute;inset:-3px;border-radius:999px;
      border:1px solid rgba(0,0,0,.06)
    }
    .iconchip i{font-size:26px;color:var(--gris-osc)}
    .card p{margin-top:6px}
    .btn.tiny{padding:8px 12px;border-width:1.5px;font-size:.9rem}
    form .btn.primary{font-size:1.05rem;padding:14px 20px}
    .btn.full{width:100%;justify-content:center}
    section#ecosistema{background:var(--gris-claro);padding:36px 0}
