    .cards6{display:grid;grid-template-columns:1fr;gap:14px}
    @media(min-width:720px){.cards6{grid-template-columns:repeat(2,1fr)}}
    @media(min-width:1024px){.cards6{grid-template-columns:repeat(3,1fr)}}
    .logo-text{
      font-family:'Manrope',sans-serif;font-weight:800;letter-spacing:-.02em;
