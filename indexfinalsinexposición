    <!-- FOCO LOCAL / Ecosistema Uruguay -->
    <section id="ecosistema" aria-labelledby="eco-title">
      <div class="container sp-32">
        <div class="section-head">
          <div class="eyebrow">FOCO LOCAL</div>
          <h2 id="eco-title">Ecosistema Uruguay: proyectos situados en el territorio</h2>
          <p class="muted">
            Operar en Uruguay implica entender un ecosistema propio: regulación, tiempos del Estado,
            formas de relación y actores clave. Desde Maldonado trabajamos con empresas, startups y organizaciones
            que quieren diseñar proyectos y casos de negocio que funcionen acá, no solo en presentaciones.
          </p>
        </div>

        <div class="eco-services">
          <h3 class="eco-sub">¿Qué podemos trabajar desde acá?</h3>
