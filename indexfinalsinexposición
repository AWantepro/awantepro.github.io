  <style>
    /* que la hamburguesa se vea siempre en mobile */
    .burger i{ color: var(--terracota); font-size: 22px; line-height: 1; }

    /* que el menú desplegado quede por encima de todo */
    #mobileMenu{ z-index: 9999; }

    /* Nav móvil (visibilidad y color del icono) */
    #mobileMenu{ display:none; z-index:9999; }
    #mobileMenu.open{ display:block; }
    .burger i{ color: var(--terracota); }

    /* Opcional: tarjetas blancas dentro de Ecosistema para más contraste */
    #ecosistema .card{ background:var(--blanco); }

    /* MENÚ MÓVIL: aparece sólo con la clase .open */
    @media (max-width:880px){
      .burger{ display:block; }
      nav.primary{ display:none; }

      #mobileMenu{
        display:none;
        position:fixed;
        right:16px;
        top:calc(var(--header-h) + 8px);
        background:var(--blanco);
        border:1px solid rgba(0,0,0,.06);
        box-shadow:var(--shadow);
        border-radius:12px;
